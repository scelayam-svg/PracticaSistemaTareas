<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="/css/tareas.css">
        <title>Sistema de Tareas</title>
    </head>
    <body>
        <h1>Sistema de Tareas</h1>

        <div class="cards-row">
            <div class="summary-card card-total">
                <div class="number"><%= tareas.length %></div>
                <div class="card-label">Total de tareas</div>
            </div>
            <div class="summary-card card-pendiente">
                <div class="number"><%= tareas.filter(t => t.estado === 'Pendiente').length %></div>
                <div class="card-label">Pendientes</div>
            </div>
            <div class="summary-card card-completada">
                <div class="number"><%= tareas.filter(t => t.estado === 'Completada').length %></div>
                <div class="card-label">Completadas</div>
            </div>
        </div>

        <div class="filtros">
            <a href="/" class="btn-filtro btn-todas <%= estadoActual === 'todas' ? 'activo' : '' %>">Todas</a>
            <a href="/?estado=Pendiente" class="btn-filtro btn-pendiente <%= estadoActual === 'Pendiente' ? 'activo' : '' %>">Pendientes</a>
            <a href="/?estado=Completada" class="btn-filtro btn-completada <%= estadoActual === 'Completada' ? 'activo' : '' %>">Completadas</a>
        </div>

        <div class="acciones-superiores">
            <a href="/tareas/nuevo" class="btn-nueva">+ Nueva Tarea</a>
        </div>

        <div class="tabla-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    <% tareas.forEach(tarea =>{ %>
                        <tr>
                            <td><%= tarea.titulo %></td>
                            <td><%= tarea.descripcion %></td>
                            <td>
                                <span class="badge <%= tarea.estado === 'Pendiente' ? 'badge-pendiente' : 'badge-completada' %>">
                                    <%= tarea.estado %>
                                </span>
                            </td>
                            <td><%= tarea.createdAt.toLocaleDateString("es-CR") %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </body>
</html>